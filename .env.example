# ID of google spreadsheets document with schedule
SCHEDULE_DOCUMENT_ID=frewhjfhjwb34hjrb234
# bot that app will use to operate channel
TELEGRAM_BOT_TOKEN=ffeferfwkljenfhjeb4hfr5
# channel, where bot will send updates
UPDATES_TELEGRAM_CHANNEL_ID=-100523452345

# path where json schedule repository will store file
SCHEDULE_FILE_REPOSIOTORY_PATH=/var/www/storage/schedule_storage.json
# path where json pinned message state repo will store file
PINNED_MESSAGE_STATE_FILE_REPOSIOTORY_PATH=/var/www/storage/pinned_message_state_storage.json
# Interval for schedule worker
SCHEDULE_WORKER_INTERVAL=10m
# Interval for upcoming events worker
UPCOMING_EVENTS_WORKER_INTERVAL=5m
# How many upcoming events to show per group in the pinned message (default: 5)
UPCOMING_EVENTS_SHOW_COUNT=5

# Optional: Gemini AI for smart update summaries (falls back to basic format if absent)
GEMINI_API_KEY=abcdefghjijklmnop
GEMINI_MODEL=gemini-2.5-flash
